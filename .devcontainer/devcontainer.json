{
  "name": "slice",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "extraNixConfig": "experimental-features = nix-command flakes"
    }
  },
  "mounts": [
    // Persist the Nix store across container rebuilds so the toolchain is not re-downloaded.
    "source=slice-nix,target=/nix,type=volume",
    // Persist direnv's allow database across container rebuilds.
    "source=slice-direnv,target=/home/vscode/.local/share/direnv,type=volume"
  ],
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "mkhl.direnv",
        "rust-lang.rust-analyzer",
        "jnoortheen.nix-ide"
      ]
    }
  }
}
